##
# static test settings for the backend application, intended for use on
# developer machines or in CI. 
# 
# with docker compose, this file is intended to be evaluated inside the
# container with: 
#   docker compose run --env-from-file test.env ...
# rather than on host with:
#   docker compose --env-file test.env run ...
## 

# db & backend service
NPD_DJANGO_SECRET='1(-i__c*t*ds1jg3xw*iiqq)(gh#2$9+0z%8m2phr3k_a&$du)'
NPD_DB_USER='postgres'
NPD_DB_PASSWORD='postgres'
NPD_DB_HOST='db'
NPD_DB_NAME='test_npd'
NPD_DB_PORT=5432
NPD_DB_ENGINE='django.db.backends.postgresql'
DEBUG=True
DJANGO_ALLOWED_HOSTS=['localhost', '127.0.0.1']
DJANGO_LOGLEVEL='INFO'
NPD_PROJECT_NAME='National Provider Directory'

# db-migrations service
FLYWAY_URL=jdbc:postgresql://${NPD_DB_HOST}:5432/test_npd
FLYWAY_USER=${NPD_DB_USER}
FLYWAY_PASSWORD=${NPD_DB_PASSWORD}
